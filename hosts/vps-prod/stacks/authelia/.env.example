# Rendu automatiquement par Komodo (pre_deploy dans komodo/stacks.toml) :
#   sops -d ../../../../secrets/vps/authelia.env > .env
# Ne jamais committer .env (ignoré par .gitignore).
TZ=Europe/Paris
AUTHELIA_SESSION_SECRET=<64 caracteres aleatoires>
AUTHELIA_STORAGE_ENCRYPTION_KEY=<64 caracteres aleatoires>
AUTHELIA_IDENTITY_VALIDATION_RESET_PASSWORD_JWT_SECRET=<64 caracteres aleatoires>
# Mot de passe de bind LDAP = mot de passe admin lldap (LLDAP_LDAP_USER_PASS).
AUTHELIA_AUTHENTICATION_BACKEND_LDAP_PASSWORD=<mot de passe admin lldap>
