# Rendu automatiquement par Komodo (pre_deploy dans komodo/stacks.toml) :
#   sops -d ../../../../secrets/vps/lldap.env > .env
# Ne jamais committer .env (ignoré par .gitignore).
TZ=Europe/Paris
LLDAP_JWT_SECRET=<64 caracteres aleatoires>
LLDAP_KEY_SEED=<64 caracteres aleatoires>
# Mot de passe de l'admin lldap (id: Cassetout). Identique a
# AUTHELIA_AUTHENTICATION_BACKEND_LDAP_PASSWORD cote Authelia.
LLDAP_LDAP_USER_PASS=<mot de passe admin lldap>
