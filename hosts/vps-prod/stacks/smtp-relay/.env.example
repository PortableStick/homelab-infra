# Rendu automatiquement par Komodo (pre_deploy dans komodo/stacks.toml) :
#   sops -d ../../../../secrets/vps/smtp-relay.env > .env
# Ne jamais committer .env (ignoré par .gitignore).
TZ=Europe/Paris
# Identifiants SMTP Brevo (Connexion / Mot de passe dans l'UI Brevo).
RELAYHOST_USERNAME=<login-brevo>@smtp-brevo.com
RELAYHOST_PASSWORD=<mot de passe SMTP Brevo>
