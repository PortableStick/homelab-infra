# mangetout — secrets rendus par pre_deploy (sops -d secrets/vindiesel/mangetout.env > .env).
# Les NON-secrets (modèles IA, URLs internes, rate-limit) sont dans compose.yaml (environment:).

# Clé OpenRouter (ai-proxy).
OPENROUTER_API_KEY=
# Jeton d'un compte de service PocketBase (émis APRÈS 1er déploiement, cf. doc).
PB_SERVICE_TOKEN=
# Secret client OIDC (généré côté Authelia ; saisi dans l'UI PocketBase OAuth2).
OIDC_CLIENT_SECRET=
# Superuser PocketBase initial (à créer à la main au 1er lancement).
PB_ADMIN_EMAIL=
PB_ADMIN_PASSWORD=
