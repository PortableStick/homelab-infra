# pelican — secrets rendus par pre_deploy (sops -d secrets/vindiesel/pelican.env > .env).
# Les NON-secrets (APP_URL, drivers, hôtes DB/Redis) sont dans compose.yaml (environment:).

# Clé d'application Laravel (format base64:...). Générée une fois ; NE PAS la changer après
# installation (elle chiffre des données sensibles en base — la perdre casse le déchiffrement).
APP_KEY=
# Mot de passe de l'utilisateur MariaDB "pelican" (lu par le Panel via DB_PASSWORD).
DB_PASSWORD=
# DOIT être identique à DB_PASSWORD : MariaDB crée l'utilisateur "pelican" avec cette valeur.
MARIADB_PASSWORD=
# Mot de passe root MariaDB.
MARIADB_ROOT_PASSWORD=
# Mot de passe Redis (cache / session / queue).
REDIS_PASSWORD=
# Secret en clair du client OIDC "pelican" déclaré côté Authelia (phase OIDC — cf. docs/pelican.md).
PELICAN_OIDC_CLIENT_SECRET=
